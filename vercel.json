{
  "version": 2,
  "name": "valora-app",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*\\.(js|css|html|png|jpg|ico|svg|txt))",
      "dest": "/public/$1"
    },
    {
      "src": "/docs",
      "dest": "/public/docs.html"
    },
    {
      "src": "/status",
      "dest": "/public/status.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/error_page.html",
      "status": 404
    }
  ]
}